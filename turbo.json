{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {},
    "test": {},

    "@oki-ui/storybook#dev": {
      "dependsOn": ["^build"],
      "cache": false,
      "persistent": true
    },

    "@oki-ui/storybook#build": {
      "dependsOn": ["^build"],
      "outputs": ["apps/storybook/dist/**"]
    }
  }
}
