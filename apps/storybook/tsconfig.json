{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@oki-ui/react": ["../../packages/react/src/index.ts"],
      "@oki-ui/tokens": ["../../packages/tokens/src/index.ts"],
      "@oki-ui/tokens/css": ["../../packages/tokens/dist/css/tokens.css"]
    }
  },
  "include": [
    ".storybook/**/*",
    "../../packages/react/src/**/*.stories.tsx"
  ]
}
