{
  "name": "@oki-ui/react",
  "version": "0.1.0",
  "description": "React components for the okiui design system",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./styles.css": "./dist/styles.css"
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch"
  },
  "keywords": ["design-system", "react", "components", "okiui"],
  "license": "MIT",
  "publishConfig": { "access": "public" },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "devDependencies": {
    "typescript": "^5.9.3",
    "tsup": "^8.5.1",
    "@types/react": "^18",
    "@types/react-dom": "^18"
  },
  "dependencies": {
    "@oki-ui/tokens": "workspace:*"
  }
}